# Etherscan v2 multichain key — one key works on Base (chainid=8453),
# Ethereum, Optimism, Arbitrum, etc. Free tier: 5 calls/sec, 100k/day.
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your-etherscan-v2-key-here

# Shared secret for /api/cron/* bearer-token auth.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here
